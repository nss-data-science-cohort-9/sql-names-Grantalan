## SQL Names

-- Save a script containing the query you used to answer each question.

SELECT *
FROM names
LIMIT 5;

-- 1. How many rows are in the names table?

SELECT COUNT(*) 
FROM names AS total_row_num;

-- 2. How many total registered people appear in the dataset?

SELECT COUNT(*) 
FROM names AS total_row_num;

-- 3. Which name had the most appearances in a single year in the dataset?

SELECT MAX(num_registered), name, year
FROM names
GROUP BY name, year
ORDER BY MAX(num_registered) DESC;

-- Linda had the most appearances in the year 1947

-- 4. What range of years are included?

SELECT MAX(year) AS max_year
FROM names;

SELECT MIN(year) AS min_year
FROM names;

-- Data years span from 1880 to 2018

-- 5. What year has the largest number of registrations?

SELECT num_registered, year
FROM names
ORDER BY num_registered DESC;

-- 1947 has the largest number of registrations.

-- 6. How many different (distinct) names are contained in the dataset?

SELECT COUNT(DISTINCT name)
FROM names;

-- Their are 98400 distinct names in the dataset.

-- 7. Are there more males or more females registered?

SELECT COUNT(*) AS female_count
FROM names
WHERE (gender = 'F');

SELECT COUNT(*) AS male_count
FROM names
WHERE (gender = 'M');

-- There are more females registered than men.

-- 8. What are the most popular male and female names overall (i.e., the most total registrations)?

SELECT num_registered, name
FROM names
WHERE (gender = 'M')
ORDER BY num_registered DESC
LIMit 10;

SELECT num_registered, name
FROM names
WHERE (gender = 'F')
ORDER BY num_registered DESC
LIMit 10;

-- James Michael and Robert are most common amoungst males. Mary and Linda are most common amoung females.

-- 9. What are the most popular boy and girl names of the first decade of the 2000s (2000 - 2009)?

SELECT num_registered, name
FROM names
WHERE (gender = 'M') 
AND year 
BETWEEN 2000 AND 2009
ORDER BY num_registered DESC
LIMIT 5;

SELECT num_registered, name
FROM names
WHERE (gender = 'F') 
AND year 
BETWEEN 2000 AND 2009
ORDER BY num_registered DESC
LIMIT 5;

-- Jacob, Michael and Emily were the most popular names in between 2000 and 2010.

-- 10. Which year had the most variety in names (i.e. had the most distinct names)?

SELECT COUNT (DISTINCT name) AS name_count, year
FROM names
GROUP BY year
ORDER BY name_count DESC;

-- 2008 has the largest number of unique names.

-- 11. What is the most popular name for a girl that starts with the letter X?

SELECT name, num_registered
FROM names
WHERE gender = 'F' 
AND name LIKE 'X%'
ORDER BY num_registered DESC
LIMIT 5;

-- XIMENA is the most popular female  ame starting with the letter "X".

-- 12. Write a query to find all (distinct) names that start with a 'Q' but whose second letter is not 'u'.

SELECT DISTINCT name
FROM names
WHERE name LIKE 'Q%'
AND name NOT LIKE '_u%';

-- 13. Which is the more popular spelling between "Stephen" and "Steven"? Use a single query to answer this question.

SELECT name, SUM(num_registered)
FROM names
WHERE name IN ('Stephen', 'Steven')
GROUP BY name
ORDER BY SUM(num_registered) DESC;

-- Steven is a more popular spelling.

-- 14. Find all names that are "unisex" - that is all names that have been used both for boys and for girls.

SELECT name
FROM names 
GROUP BY name
HAVING COUNT(DISTINCT gender) > 1;

-- 15. Find all names that have made an appearance in every single year since 1880.

SELECT name
FROM names
WHERE year BETWEEN 1880 AND 2018
GROUP BY name
HAVING COUNT(DISTINCT year) = 138;

SELECT *
FROM names
ORDER BY year DESC
LIMIT 5;

-- 16. Find all names that have only appeared in one year.

SELECT name
FROM names
GROUP BY name
HAVING COUNT(DISTINCT year) = 1;

-- 17. Find all names that only appeared in the 1950s.

SELECT name
FROM names
GROUP BY name
HAVING MIN(year) >= 1950
AND MAX(year) <= 1959;

-- 18. Find all names that made their first appearance in the 2010s.

SELECT name
FROM names
GROUP BY name
HAVING MIN(year) >= 2010 
AND MIN(year) <= 2019;

-- 19. Find the names that have not been used in the longest.

SELECT name
FROM names
GROUP BY name
ORDER BY MAX(year) ASC;

